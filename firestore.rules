rules_version = '2';

/**
 * VoteWise Firestore Security Rules
 * Security model: deny-all by default, explicit allow per route.
 * All write operations require authentication.
 * Read operations on public data (faqs, journeySteps, timeline)
 * are allowed without authentication for accessibility.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────

    /** Returns true if the request has a valid Firebase Auth token */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Returns true if the authenticated user matches the document */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Returns true if the request does not contain PII fields */
    function noSensitiveFields() {
      return !request.resource.data.keys().hasAny(
        ['password', 'ssn', 'creditCard', 'bankAccount']
      );
    }

    // ── Default: Deny all ───────────────────────────────────────
    // Explicit catch-all deny. Any collection not listed below
    // is completely inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Users: only own document ────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && noSensitiveFields();
      allow update: if isOwner(userId) && noSensitiveFields()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email', 'createdAt']);
      allow delete: if false;

      // ── Chat History: subcollection under user ────────────────
      match /chatHistory/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['role', 'content', 'timestamp'])
          && request.resource.data.role in ['user', 'model']
          && request.resource.data.content is string
          && request.resource.data.content.size() <= 2000;
        allow update, delete: if false;
      }
    }

    // ── Rate Limits: server-managed ─────────────────────────────
    match /rateLimits/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ── Public Collections: read-only ───────────────────────────
    // These are read-only public data seeded at deploy time.
    // No user can write to these collections.

    match /faqs/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /journeySteps/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /timelinePhases/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
