# ═══════════════════════════════════════════════════════
# VoteWise — Environment Variables Template
# ═══════════════════════════════════════════════════════
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values from Firebase Console
# 3. NEVER commit .env.local — it is in .gitignore
#
# WHERE TO GET THESE VALUES:
# Firebase Console → Project Settings → Your apps → Web app
# https://console.firebase.google.com
# ═══════════════════════════════════════════════════════

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id-here
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=1:000000000000:web:your_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ═══════════════════════════════════════════════════════
# GEMINI API KEY — DO NOT ADD HERE
# ═══════════════════════════════════════════════════════
# The Gemini API key is NEVER stored in .env files.
# It is set ONLY in Firebase Functions environment:
#
#   firebase functions:secrets:set GEMINI_API_KEY
#   (or use defineSecret in Cloud Functions v2)
#
# Get a free key at: https://aistudio.google.com/app/apikey
# ═══════════════════════════════════════════════════════
